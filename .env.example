# Copy to `.env` for local values. `npm run prepare:server` loads `.env` from this directory.

# Optional: bundle step runs `just release` in this directory and copies the built binary
# from <path>/target/release/ into server/ instead of downloading a GitHub release.
WITCHERSCRIPT_LSP_PATH=../witcherscript-language

# Optional: override the pinned LSP release tag (default lives in package.json under
# `witcherscriptLsp.version`). Useful for testing pre-releases without a version bump.
# WITCHERSCRIPT_LSP_VERSION=v0.3.2
