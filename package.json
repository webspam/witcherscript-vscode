{
  "name": "witcherscript-language-features",
  "displayName": "WitcherScript Language Features",
  "description": "Minimal WitcherScript diagnostics, navigation, and hover support.",
  "version": "0.1.2",
  "publisher": "webspam",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/webspam/witcherscript-vscode.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./extension.js",
  "scripts": {
    "check": "node --check extension.js && node --check scripts/prepare-server.js",
    "prepare:server": "node scripts/prepare-server.js",
    "package": "npm run prepare:server && vsce package"
  },
  "contributes": {
    "languages": [
      {
        "id": "witcherscript",
        "aliases": [
          "WitcherScript",
          "Witcher Script"
        ],
        "extensions": [
          ".ws"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "witcherscript",
        "scopeName": "source.witcherscript",
        "path": "./syntaxes/witcherscript.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "WitcherScript",
      "properties": {
        "witcherscript.server.path": {
          "type": "string",
          "default": "",
          "description": "Optional path to the witcherscript-lsp executable. If empty, the extension uses the bundled server binary."
        },
        "witcherscript.gameDirectory": {
          "type": "string",
          "default": "",
          "description": "Absolute path to The Witcher 3 game directory (e.g. C:\\games\\The Witcher 3 Wild Hunt GOTY). Used by the language server to locate base game scripts."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.0"
  }
}
