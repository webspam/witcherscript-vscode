{
  "name": "witcherscript-language-features",
  "displayName": "WitcherScript Language Features",
  "description": "Minimal WitcherScript diagnostics, navigation, and hover support.",
  "version": "0.1.0",
  "publisher": "lightrewrite",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:witcherscript"
  ],
  "main": "./extension.js",
  "scripts": {
    "check": "node --check extension.js && node --check scripts/prepare-server.js",
    "prepare:server": "node scripts/prepare-server.js",
    "package": "npm run prepare:server && vsce package"
  },
  "contributes": {
    "languages": [
      {
        "id": "witcherscript",
        "aliases": [
          "WitcherScript",
          "Witcher Script"
        ],
        "extensions": [
          ".ws"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "witcherscript",
        "scopeName": "source.witcherscript",
        "path": "./syntaxes/witcherscript.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "WitcherScript",
      "properties": {
        "witcherscript.server.path": {
          "type": "string",
          "default": "",
          "description": "Optional path to the witcherscript-lsp executable. If empty, the extension tries the local parser target directory."
        },
        "witcherscript.server.extraScriptRoots": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional WitcherScript roots for future indexing of external game scripts."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.0"
  }
}
