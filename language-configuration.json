{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    {
      "open": "{",
      "close": "}"
    },
    {
      "open": "[",
      "close": "]"
    },
    {
      "open": "(",
      "close": ")"
    },
    {
      "open": "/*",
      "close": " */",
      "notIn": ["string"]
    },
    {
      "open": "\"",
      "close": "\""
    },
    {
      "open": "'",
      "close": "'"
    }
  ],
  "onEnterRules": [
    {
      "beforeText": "^\\s*/\\*(?!/)([^\\*]|\\*(?!/))*$",
      "afterText": "^\\s*\\*/$",
      "action": { "indent": "indentOutdent", "appendText": " * " }
    },
    {
      "beforeText": "^\\s*/\\*(?!/)([^\\*]|\\*(?!/))*$",
      "action": { "indent": "none", "appendText": " * " }
    },
    {
      "beforeText": "^(\\t|[ ])*\\*([ ]([^\\*]|\\*(?!/))*)?$",
      "previousLineText": "(?=^(\\s*(/\\*\\*?|\\*)).*)(?=(?!(\\s*\\*/))).",
      "action": { "indent": "none", "appendText": "* " }
    },
    {
      "beforeText": "^(\\t|[ ])*[ ]\\*/\\s*$",
      "action": { "indent": "none", "removeText": 1 }
    },
    {
      "beforeText": "^(\\t|[ ])*[ ]\\*[^/]*\\*/\\s*$",
      "action": { "indent": "none", "removeText": 1 }
    }
  ]
}
