{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "WitcherScript",
  "scopeName": "source.witcherscript",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#names"
    },
    {
      "include": "#annotations"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#numbers"
    }
  ],
  "repository": {
    "annotations": {
      "patterns": [
        {
          "name": "storage.type.annotation.witcherscript",
          "match": "@[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.witcherscript",
          "match": "//.*$"
        },
        {
          "name": "comment.block.witcherscript",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.witcherscript",
          "match": "\\b(if|else|switch|case|default|for|foreach|in|while|do|break|continue|return|state|event|entry|timer|function|new|delete)\\b"
        },
        {
          "name": "storage.modifier.witcherscript",
          "match": "\\b(public|private|protected|abstract|final|static|const|import|editable|saved|exec|latent|optional|out)\\b"
        },
        {
          "name": "storage.type.witcherscript",
          "match": "\\b(class|struct|enum|var|extends|statemachine|defaults)\\b"
        },
        {
          "name": "constant.language.witcherscript",
          "match": "\\b(true|false|NULL|this|super|parent)\\b"
        }
      ]
    },
    "names": {
      "patterns": [
        {
          "name": "constant.other.symbol.quoted.single.witcherscript",
          "begin": "'",
          "end": "'"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.witcherscript",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.witcherscript",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.witcherscript",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.witcherscript",
          "match": "\\b(void|bool|int|float|string|name)\\b"
        }
      ]
    }
  }
}
